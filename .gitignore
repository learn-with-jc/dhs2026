cat > .gitignore << 'EOF'
# Environment — NEVER commit secrets
.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
eggs/
*.egg
.eggs/

# Virtual environment
.venv/
venv/
env/
ENV/

# VS Code
.vscode/
*.code-workspace

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# macOS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Generated data — too large for GitHub
data/processed/vector_store/
data/processed/audit_logs/

# Logs
*.log
logs/

# Test cache
.pytest_cache/
.coverage
htmlcov/

# Sentence transformers cache
.cache/